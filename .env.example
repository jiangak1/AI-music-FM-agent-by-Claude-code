# AI 电台配置文件
# 复制此文件为 .env 并填入你的配置

# OpenAI 兼容 API 配置
AI_API_KEY=sk-your-api-key-here
AI_API_BASE=https://api.openai.com/v1
AI_MODEL=gpt-4o

# 服务器端口
PORT=3000

# TTS 语音合成配置（OpenAI 兼容 API，留空则复用 AI 配置）
TTS_API_KEY=
TTS_API_BASE=
TTS_MODEL=mimo-v2.5-tts
TTS_VOICE=mimo_default

# OpenWeather 天气 API 配置（https://openweathermap.org/api）
OPENWEATHER_API_KEY=
OPENWEATHER_CITY=Beijing

# 网易云音乐 API 服务端口（内部使用，无需修改）
NCM_PORT=4000

# 本地音乐目录（可选，留空跳过扫描）
MUSIC_DIR=
